// aricode-ml: tests/test_attention.ari
//
// Numerical sanity check for attention_f32 against a hand-computed
// 2-token, d_in = d_head = 2 example.  W_Q = W_K = W_V = I (identity)
// so Q = K = V = X and scores reduce to plain dot products.
//
// X = [[1, 0],
//      [0, 1]]
// Causal-masked:
//   row 0: scores [1/√2, −∞]   softmax → [1.0, 0.0]
//   row 1: scores [0, 1/√2]    softmax → [exp(−1/√2)/Z, 1/Z]
//                              Z = exp(−1/√2) + 1 ≈ 1.4929
//                              → [0.330, 0.670]
// out[0] = 1.0·V[0] + 0.0·V[1] = [1, 0]
// out[1] = 0.330·V[0] + 0.670·V[1] = [0.330, 0.670]

import "../attention_f32.ari" as attn;

fn set_identity_2x2(W: i32) -> i32 {
    arr_f32_set(W, 0, 1.0); arr_f32_set(W, 1, 0.0);
    arr_f32_set(W, 2, 0.0); arr_f32_set(W, 3, 1.0);
    return 0;
}

fn close_within(got: f64, expect: f64, tol: f64) -> i32 {
    let diff: f64 = got - expect;
    if (diff < 0.0) { diff = 0.0 - diff; }
    if (diff > tol) { return 0; }
    return 1;
}

fn main() -> i32 {
    let seq: i32 = 2;
    let d:   i32 = 2;
    let causal: i32 = 1;

    let X: i32 = arr_f32_new(seq * d);
    arr_f32_set(X, 0, 1.0); arr_f32_set(X, 1, 0.0);
    arr_f32_set(X, 2, 0.0); arr_f32_set(X, 3, 1.0);

    let W_Q: i32 = arr_f32_new(d * d); set_identity_2x2(W_Q);
    let W_K: i32 = arr_f32_new(d * d); set_identity_2x2(W_K);
    let W_V: i32 = arr_f32_new(d * d); set_identity_2x2(W_V);

    let b_Q: i32 = arr_f32_new(d); arr_f32_fill(b_Q, 0.0);
    let b_K: i32 = arr_f32_new(d); arr_f32_fill(b_K, 0.0);
    let b_V: i32 = arr_f32_new(d); arr_f32_fill(b_V, 0.0);

    let out: i32 = arr_f32_new(seq * d);

    // Build the attention descriptor with all scratch buffers.
    let desc: i32 = attn.attn_alloc_desc_f32(seq, d, d, causal);
    arr_set(desc,  0, X);
    arr_set(desc,  1, W_Q); arr_set(desc,  2, b_Q);
    arr_set(desc,  3, W_K); arr_set(desc,  4, b_K);
    arr_set(desc,  5, W_V); arr_set(desc,  6, b_V);
    arr_set(desc, 11, out);

    attn.attention_forward_f32(desc);

    let ok: i32 = 1;
    let r1: i32 = close_within(arr_f32_get(out, 0), 1.0,   0.001);
    let r2: i32 = close_within(arr_f32_get(out, 1), 0.0,   0.001);
    let r3: i32 = close_within(arr_f32_get(out, 2), 0.330, 0.005);
    let r4: i32 = close_within(arr_f32_get(out, 3), 0.670, 0.005);
    if (r1 == 0) { ok = 0; }
    if (r2 == 0) { ok = 0; }
    if (r3 == 0) { ok = 0; }
    if (r4 == 0) { ok = 0; }

    if (ok == 1) {
        print_str("ATTENTION_TEST_OK");
    } else {
        print_str("FAIL");
        print_str("out[0,0]:"); print_f64(arr_f32_get(out, 0), 6);
        print_str("out[0,1]:"); print_f64(arr_f32_get(out, 1), 6);
        print_str("out[1,0]:"); print_f64(arr_f32_get(out, 2), 6);
        print_str("out[1,1]:"); print_f64(arr_f32_get(out, 3), 6);
    }
    return 0;
}
