// aricode-ml: tests/test_sampling.ari
//
// Unit tests for sampling_f32: greedy, top-k filter, temperature.

import "../sampling_f32.ari" as samp;

fn main() -> i32 {
    let ok: i32 = 1;

    // ---- greedy ----
    let L: i32 = arr_f32_new(8);
    arr_f32_set(L, 0, 0.1);
    arr_f32_set(L, 1, 1.4);
    arr_f32_set(L, 2, -0.5);
    arr_f32_set(L, 3, 0.9);
    arr_f32_set(L, 4, 2.7);   // argmax
    arr_f32_set(L, 5, 0.3);
    arr_f32_set(L, 6, -1.0);
    arr_f32_set(L, 7, 1.0);
    let g: i32 = samp.sample_greedy_f32(L);
    if (g != 4) {
        print_str("FAIL: greedy expected 4, got:");
        print_int(g);
        ok = 0;
    }

    // ---- top-k filter (k=2 keeps the top 2 = idx 4 and idx 1) ----
    let L2: i32 = arr_f32_new(8);
    arr_f32_set(L2, 0, 0.1);
    arr_f32_set(L2, 1, 1.4);
    arr_f32_set(L2, 2, -0.5);
    arr_f32_set(L2, 3, 0.9);
    arr_f32_set(L2, 4, 2.7);
    arr_f32_set(L2, 5, 0.3);
    arr_f32_set(L2, 6, -1.0);
    arr_f32_set(L2, 7, 1.0);
    samp.sample_topk_filter_f32(L2, 2);
    // After filter: idx 1 and idx 4 keep original values, others are
    // sentinel < -100000.  argmax still 4, but idx 7 (1.0) should
    // have been filtered to a large-negative.
    let neg_thresh: f64 = 0.0 - 1000.0;
    let v7: f64 = arr_f32_get(L2, 7);
    if (v7 > neg_thresh) {
        print_str("FAIL: top-k did not filter idx 7, got:");
        print_f64(v7, 3);
        ok = 0;
    }
    let v1: f64 = arr_f32_get(L2, 1);
    if (v1 < 1.3) {
        print_str("FAIL: top-k filtered idx 1 (top-2), got:");
        print_f64(v1, 3);
        ok = 0;
    }
    let v4: f64 = arr_f32_get(L2, 4);
    if (v4 < 2.6) {
        print_str("FAIL: top-k filtered idx 4 (top-1), got:");
        print_f64(v4, 3);
        ok = 0;
    }

    // ---- temperature: with very low temp + uniform sample, should
    // collapse to greedy.  rng_unit=0.5 lands in the dominant bin. ----
    let L3: i32 = arr_f32_new(4);
    arr_f32_set(L3, 0, 0.0);
    arr_f32_set(L3, 1, 0.0);
    arr_f32_set(L3, 2, 5.0);   // dominant
    arr_f32_set(L3, 3, 0.0);
    let t: i32 = samp.sample_temperature_f32(L3, 0.1, 0.5);
    if (t != 2) {
        print_str("FAIL: low-temp expected 2, got:");
        print_int(t);
        ok = 0;
    }

    if (ok == 1) {
        print_str("SAMPLING_OK");
    } else {
        print_str("SAMPLING_FAIL");
    }
    return 0;
}
