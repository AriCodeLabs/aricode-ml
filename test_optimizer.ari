// aricode-stdlib: ml/test_optimizer.ari
// Tests sgd_update, zero_gradients, clip_gradients.

import "optimizer.ari" as opt;

fn main() -> i32 {
    // SGD: w = [1.0, 2.0, 3.0], g = [0.1, 0.2, 0.3], lr = 0.5
    //   → w' = [0.95, 1.90, 2.85]
    let w: i32 = arr_f64_new(3);
    arr_f64_set(w, 0, 1.0);
    arr_f64_set(w, 1, 2.0);
    arr_f64_set(w, 2, 3.0);

    let g: i32 = arr_f64_new(3);
    arr_f64_set(g, 0, 0.1);
    arr_f64_set(g, 1, 0.2);
    arr_f64_set(g, 2, 0.3);

    opt.sgd_update(w, g, 3, 0.5);

    print_float(arr_f64_get(w, 0));   // 0.95
    print_float(arr_f64_get(w, 1));   // 1.90
    print_float(arr_f64_get(w, 2));   // 2.85

    // zero_gradients: g → [0, 0, 0]
    opt.zero_gradients(g, 3);
    print_float(arr_f64_get(g, 0));   // 0
    print_float(arr_f64_get(g, 2));   // 0

    // clip_gradients with max_val = 1.0: [-5.0, 0.5, 3.0] → [-1.0, 0.5, 1.0]
    let c: i32 = arr_f64_new(3);
    arr_f64_set(c, 0, -5.0);
    arr_f64_set(c, 1, 0.5);
    arr_f64_set(c, 2, 3.0);
    opt.clip_gradients(c, 3, 1.0);
    print_float(arr_f64_get(c, 0));   // -1.0
    print_float(arr_f64_get(c, 1));   // 0.5
    print_float(arr_f64_get(c, 2));   // 1.0

    mem_free(w); mem_free(g); mem_free(c);
    return 0;
}
