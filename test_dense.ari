// aricode-stdlib: ml/test_dense.ari
// Tests dense_forward, dense_apply_relu, and mse_loss.
//
// Shape: 2 inputs -> 3 outputs (dense layer).
// Expected forward pass, verified by hand below.

import "dense.ari" as dense;

fn main() -> i32 {
    let n_in: i32  = 2;
    let n_out: i32 = 3;

    // weights[j*n_in + i]:
    //   j=0: 1.0, 2.0   (w0·x0 + w1·x1)
    //   j=1: -1.0, 0.5
    //   j=2: 0.0, 3.0
    let w: i32 = arr_f64_new(6);
    arr_f64_set(w, 0,  1.0); arr_f64_set(w, 1,  2.0);
    arr_f64_set(w, 2, -1.0); arr_f64_set(w, 3,  0.5);
    arr_f64_set(w, 4,  0.0); arr_f64_set(w, 5,  3.0);

    let b: i32 = arr_f64_new(3);
    arr_f64_set(b, 0,  0.5);
    arr_f64_set(b, 1, -0.2);
    arr_f64_set(b, 2,  1.0);

    let x: i32 = arr_f64_new(2);
    arr_f64_set(x, 0, 1.0);
    arr_f64_set(x, 1, 2.0);

    let y: i32 = arr_f64_new(3);

    dense.dense_forward(w, b, x, y, n_in, n_out);

    // Expected:
    //   y[0] = 0.5 + (1·1 + 2·2)   = 5.5
    //   y[1] = -0.2 + (-1·1 + 0.5·2) = -0.2
    //   y[2] = 1.0 + (0·1 + 3·2)     = 7.0
    print_float(arr_f64_get(y, 0));   // 5.5
    print_float(arr_f64_get(y, 1));   // -0.2
    print_float(arr_f64_get(y, 2));   // 7.0

    // ReLU: y[1] = -0.2 → 0, others unchanged.
    dense.dense_apply_relu(y, n_out);
    print_float(arr_f64_get(y, 0));   // 5.5
    print_float(arr_f64_get(y, 1));   // 0
    print_float(arr_f64_get(y, 2));   // 7.0

    // MSE vs target [5.5, 0.0, 6.0]: diffs = [0, 0, 1], mean sq = 1/3.
    let t: i32 = arr_f64_new(3);
    arr_f64_set(t, 0, 5.5);
    arr_f64_set(t, 1, 0.0);
    arr_f64_set(t, 2, 6.0);
    let loss: f64 = dense.mse_loss(y, t, n_out);
    print_float(loss);                // ~0.333333

    mem_free(w); mem_free(b); mem_free(x); mem_free(y); mem_free(t);
    return 0;
}
